# 1. FIREBASE CONFIGURATION
# ============================================================================
FIREBASE_API_KEY=AIzaSyA4IGmEv_bPt4Q5dnxjT2FIySP3JvAhQ20
FIREBASE_AUTH_DOMAIN=site-cg51.firebaseapp.com
FIREBASE_PROJECT_ID=site-cg51
FIREBASE_STORAGE_BUCKET=site-cg51.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=532992433947
FIREBASE_APP_ID=1:532992433947:web:0ad401c53e6feeb0663dbe

# 2. AUTHENTICATION - Comptes par Grade
# ============================================================================
# Format: email@domain.fr / mot_de_passe_grade

# Apprenti
AUTH_APPRENTI_EMAIL=apprenti@cg51-virtuel.fr
AUTH_APPRENTI_PASSWORD=apprenti_password

# Compagnon
AUTH_COMPAGNON_EMAIL=compagnon@cg51-virtuel.fr
AUTH_COMPAGNON_PASSWORD=compagnon_password

# Maître
AUTH_MAITRE_EMAIL=maitre@cg51-virtuel.fr
AUTH_MAITRE_PASSWORD=maitre_password

# Architecte (Admin)
AUTH_ARCHITECTE_EMAIL=architecte@cg51-virtuel.fr
AUTH_ARCHITECTE_PASSWORD=architecte_admin_password

# 3. STRIPE CONFIGURATION (Paiement en ligne)
# ============================================================================
# Récupérer sur https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_HERE

# Produits Stripe (pré-configurés)
STRIPE_PRICE_ID_LETTERING=price_YOUR_LETTERING_ID
STRIPE_PRICE_ID_FINISHING=price_YOUR_FINISHING_ID

# 4. CLAUDE API (Anthropic - Suggestions IA)
# ============================================================================
# Récupérer sur https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE

# 5. SENDGRID (Emails transactionnels)
# ============================================================================
# Récupérer sur https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@cg51-virtuel.fr
SENDGRID_FROM_NAME=Comte Guifré - Temple Virtuel

# Emails de notification
SENDGRID_ADMIN_EMAIL=architecte@cg51-virtuel.fr
SENDGRID_SUPPORT_EMAIL=support@cg51-virtuel.fr

# 6. GOOGLE SERVICES
# ============================================================================

# Google Analytics 4
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Google Cloud Storage (optionnel - alternative à Firebase Storage)
GOOGLE_CLOUD_PROJECT_ID=site-cg51
GOOGLE_CLOUD_STORAGE_BUCKET=site-cg51-backups

# 7. CLOUDFLARE CONFIGURATION (CDN & Security)
# ============================================================================
# Récupérer sur https://dash.cloudflare.com/
CLOUDFLARE_ZONE_ID=YOUR_ZONE_ID
CLOUDFLARE_API_TOKEN=YOUR_API_TOKEN
CLOUDFLARE_API_KEY=YOUR_API_KEY
CLOUDFLARE_EMAIL=admin@cg51-virtuel.fr

# Cloudflare Workers (optional - serverless)
CLOUDFLARE_WORKER_URL=https://your-worker.workers.dev

# 7b. CLOUDFLARE PAGES (Hosting)
# ============================================================================
CLOUDFLARE_PAGES_PROJECT=comte-guifre-temple
CLOUDFLARE_PAGES_BRANCH=main
CLOUDFLARE_PAGES_DEPLOYMENT_WEBHOOK=YOUR_WEBHOOK_URL

# 8. DATABASE CONFIGURATION
# ============================================================================

# Firebase Firestore (utilisé - configuration automatique)
# Pas de URL nécessaire - Firebase gère tout

# PostgreSQL (optionnel - pour analytics avancées)
DATABASE_URL=postgresql://user:password@localhost:5432/cg51_templevirtuel

# 9. APPLICATION CONFIGURATION
# ============================================================================

# URLs
NEXT_PUBLIC_APP_URL=https://cg51-virtuel.fr
NEXT_PUBLIC_API_BASE_URL=https://api.cg51-virtuel.fr

# Environnement
NODE_ENV=production
ENVIRONMENT=production

# Logging
LOG_LEVEL=info
DEBUG=false

# 10. CONFIGURATEUR SETTINGS
# ============================================================================

# Tarifs par défaut (peuvent être modifiés dans Firestore)
CONFIGURATEUR_TVA_RATE=0.20
CONFIGURATEUR_MIN_ORDER=10.00
CONFIGURATEUR_SHIPPING_THRESHOLD=150.00
CONFIGURATEUR_SHIPPING_COST=30.00

# Délais de production
CONFIGURATEUR_PRODUCTION_DELAY_DAYS=10
CONFIGURATEUR_RUSH_DELAY_DAYS=3
RUSH_ORDER_SURCHARGE=0.25

# 11. SECURITY & SECRETS
# ============================================================================

# JWT Secret (si utilisation de tokens)
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE

# Encryption key pour données sensibles
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# CORS Configuration
CORS_ORIGIN=https://cg51-virtuel.fr,https://www.cg51-virtuel.fr

# 12. INTEGRATIONS OPTIONNELLES
# ============================================================================

# Sentry (Error tracking)
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# 13. RATE LIMITING & QUOTAS
# ============================================================================

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Stripe Quota
STRIPE_MONTHLY_QUOTA=50000

# Claude API Quota
CLAUDE_API_MONTHLY_QUOTA=100000

# 14. MONITORING & ANALYTICS
# ============================================================================

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_ALERT_THRESHOLD_MS=2000

# User Analytics
ENABLE_USER_ANALYTICS=true
ANALYTICS_RETENTION_DAYS=90

# ============================================================================
# NOTES DE CONFIGURATION
# ============================================================================
#
# 1. DÉVELOPPEMENT LOCAL:
#    - Copier ce fichier: cp .env.example .env.local
#    - Remplir les valeurs avec les clés de développement
#    - .env.local est ignoré par git (sécurité)
#
# 2. PRODUCTION:
#    - Utiliser des variables d'environnement du serveur
#    - Jamais commiter les vraies clés dans le repo
#    - Utiliser secrets manager (AWS Secrets, Google Secret Manager, etc.)
#
# 3. FIREBASE SETUP:
#    - Project: site-cg51
#    - Firestore Database: active et sécurisée par rules
#    - Firebase Storage: 15MB max par fichier
#    - Authentication: Email/Password actif
#
# 4. STRIPE SETUP:
#    - Mode Test par défaut (pk_test_, sk_test_)
#    - Webhooks configurés sur: /api/stripe/webhook
#    - Pricing à configurer dans Stripe Dashboard
#
# 5. CLOUDFLARE SETUP:
#    - Zone configurée pour cg51-virtuel.fr
#    - Pages deployment automatique
#    - Workers pour serverless functions
#
# 6. FIRESTORE RULES:
#    - Fichier: firestore.rules
#    - Commande deploy: firebase deploy --only firestore:rules
#
# ============================================================================
